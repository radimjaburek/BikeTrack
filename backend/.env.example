# Získáš po registraci na https://developer.garmin.com/gc-developer-program/overview/
GARMIN_CONSUMER_KEY=your_consumer_key_here
GARMIN_CONSUMER_SECRET=your_consumer_secret_here

# Veřejná URL tohoto serveru (musí být HTTPS pro produkci)
BACKEND_URL=https://your-server.com

# URL schéma Flutter aplikace (musí odpovídat AndroidManifest.xml)
APP_CALLBACK_SCHEME=biketrack

PORT=3000
